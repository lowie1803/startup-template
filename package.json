{
  "name": "fplang",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "A factor / alpha expression language for FPL analytics — browser-native and node-ready.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "run":      "tsx bin/run.ts",
    "repl":     "tsx bin/repl.ts",
    "llm":      "tsx bin/llm-harness.ts",
    "test":     "vitest",
    "test:run": "vitest run",
    "build":    "tsup src/index.ts --format esm,cjs --dts --out-dir dist",
    "typecheck":"tsc --noEmit",
    "lint":     "eslint .",
    "snapshot": "node data/snapshot-fpl.mjs",
    "validate-source": "tsx bin/validate-source.ts",
    "example":           "tsx examples/quickstart.ts",
    "example:community": "tsx examples/community.ts",
    "gen:dictionary":    "tsx scripts/build-field-dictionary.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
